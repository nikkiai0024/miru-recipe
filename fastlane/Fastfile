default_platform(:ios)

platform :ios do
  desc "Submit the prepared App Store version for review"
  lane :submit_app_review do
    api_key_id = ENV.fetch("ASC_API_KEY_ID")
    api_key = app_store_connect_api_key(
      key_id: api_key_id,
      issuer_id: ENV.fetch("ASC_API_ISSUER_ID"),
      key_filepath: ENV.fetch(
        "ASC_API_KEY_PATH",
        File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{api_key_id}.p8")
      ),
      duration: 1200,
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.mirurecipe.app",
      app: 6760578027,
      app_version: ENV.fetch("APP_VERSION", "1.0.10"),
      build_number: ENV.fetch("BUILD_NUMBER", "17"),
      metadata_path: "fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
      }
    )
  end

  desc "Update ASO metadata only (keywords, promotional text) - no review needed"
  lane :aso_update do
    deliver(
      app_identifier: "com.mirurecipe.app",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      force: true,
      run_precheck_before_submit: false,
      edit_live: true
    )
  end

  desc "Update keywords only (live version)"
  lane :update_keywords do
    deliver(
      app_identifier: "com.mirurecipe.app",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      force: true,
      run_precheck_before_submit: false,
      edit_live: true
    )
  end
end

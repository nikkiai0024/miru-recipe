default_platform(:ios)

platform :ios do
  desc "Update ASO metadata only (keywords, promotional text) - no review needed"
  lane :aso_update do
    deliver(
      app_identifier: "com.mirurecipe.app",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      force: true,
      run_precheck_before_submit: false,
      edit_live: true
    )
  end

  desc "Update keywords only (live version)"
  lane :update_keywords do
    deliver(
      app_identifier: "com.mirurecipe.app",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: true,
      force: true,
      run_precheck_before_submit: false,
      edit_live: true
    )
  end
end
